<?xml version="1.0"?>
<robot name="/home/CNF2025495045/workspace/nav_for_4WS/src/robot_webots_sim/worlds/four_wheel_steering_robot.urdf" xmlns:xacro="http://ros.org/wiki/xacro">
  <link name="base_footprint"/>
  
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/> 
  </joint>
  
  <link name="base_link">
  </link>

  <joint name="steer_rr" type="continuous">
    <parent link="base_link"/>
    <child link="steer_rr_solid"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10"/>
    <origin xyz="-0.175 -0.175 0" rpy="0 0 0"/>
  </joint>
  
  <link name="steer_rr_solid">
  </link>
  
  <joint name="drive_rr" type="continuous">
    <parent link="steer_rr_solid"/>
    <child link="drive_rr_solid"/>
    <axis xyz="0.000002 -0.000004 1"/>
    <limit effort="10" velocity="40"/>
    <origin xyz="0 0 0" rpy="1.570792 0.000002 3.141591"/>
  </joint>
  
  <link name="drive_rr_solid">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
  </link>
  
  <joint name="steer_rl" type="continuous">
    <parent link="base_link"/>
    <child link="steer_rl_solid"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10"/>
    <origin xyz="-0.175 0.175 0" rpy="0 0 0"/>
  </joint>

  <link name="steer_rl_solid">
  </link>

  <joint name="drive_rl" type="continuous">
    <parent link="steer_rl_solid"/>
    <child link="drive_rl_solid"/>
    <axis xyz="0.000002 -0.000004 1"/>
    <limit effort="10" velocity="40"/>
    <origin xyz="0 0 0" rpy="1.570792 0.000002 3.141591"/>
  </joint>

  <link name="drive_rl_solid">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="steer_fr" type="continuous">
    <parent link="base_link"/>
    <child link="steer_fr_solid"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10"/>
    <origin xyz="0.175 -0.175 0" rpy="0 0 0"/>
  </joint>

  <link name="steer_fr_solid">
  </link>

  <joint name="drive_fr" type="continuous">
    <parent link="steer_fr_solid"/>
    <child link="drive_fr_solid"/>
    <axis xyz="0.000002 -0.000004 1"/>
    <limit effort="10" velocity="40"/>
    <origin xyz="0 0 0" rpy="1.570792 0.000002 3.141591"/>
  </joint>

  <link name="drive_fr_solid">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="steer_fl" type="continuous">
    <parent link="base_link"/>
    <child link="steer_fl_solid"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10"/>
    <origin xyz="0.175 0.175 0" rpy="0 0 0"/>
  </joint>

  <link name="steer_fl_solid">
  </link>

  <joint name="drive_fl" type="continuous">
    <parent link="steer_fl_solid"/>
    <child link="drive_fl_solid"/>
    <axis xyz="0.000002 -0.000004 1"/>
    <limit effort="10" velocity="40"/>
    <origin xyz="0 0 0" rpy="1.570795 -0.999998 3.141589"/>
  </joint>

  <link name="drive_fl_solid">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="imu">
  </link>

  <joint name="base_link_imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="gps">
  </link>

  <joint name="base_link_gps_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="pen">
  </link>

  <joint name="base_link_pen_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pen"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="lidar">
  </link>
  <joint name="base_link_lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar"/>
    <origin xyz="0.2 0 0.06" rpy="0 0 0"/>
  </joint>

  <link name="lidar_optical">
  </link>
  <joint name="lidar_to_optical_joint" type="fixed">
    <parent link="lidar"/>  <!-- 你原有雷达的link名 -->
    <child link="lidar_optical"/>
    <origin xyz="0 0 0" 
            rpy="0 0 0"/>
  </joint>
  
  <link name="tof">
  </link>
  <joint name="base_link_tof_joint" type="fixed">
    <parent link="base_link"/>
    <child link="tof"/>
    <origin xyz="0.218435 0 0.031895" rpy="0 -0.261795 0"/>
  </joint>

  <link name="tof_optical">
  </link>
  <joint name="tof_to_optical_joint" type="fixed">
    <parent link="tof"/>
    <child link="tof_optical"/>
    <origin xyz="0 0 0" 
            rpy="1.570796 3.141592 1.570796"/>
  </joint>
  
</robot>
