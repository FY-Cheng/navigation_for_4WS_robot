  <joint name="steer_rl" type="continuous">
    <parent link="base_link"/>
    <child link="steer_rl_solid"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10"/>
    <origin xyz="-0.175 0.175 0" rpy="0 0 0"/>
  </joint>

  <link name="steer_rl_solid">
  </link>

  <joint name="drive_rl" type="continuous">
    <parent link="steer_rl_solid"/>
    <child link="drive_rl_solid"/>
    <axis xyz="0.000002 -0.000004 1"/>
    <limit effort="10" velocity="40"/>
    <origin xyz="0 0 0" rpy="1.570792 0.000002 3.141591"/>
  </joint>

  <link name="drive_rl_solid">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
  </link>

